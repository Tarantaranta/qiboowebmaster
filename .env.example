# ============================================================
# Webmaster App - Environment Variables
# ============================================================
# Copy this file to .env.local and fill in the values
# cp .env.example .env.local
# ============================================================

# ------------------------------------------------------------
# Supabase (Required)
# Get these from: https://app.supabase.com → Project Settings → API
# ------------------------------------------------------------
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-supabase-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-supabase-service-role-key

# ------------------------------------------------------------
# Telegram Bot Alerts (Required for alert notifications)
# Create a bot via @BotFather on Telegram
# Get chat ID by messaging @userinfobot
# ------------------------------------------------------------
TELEGRAM_BOT_TOKEN=your-telegram-bot-token
TELEGRAM_CHAT_ID=your-telegram-chat-id

# ------------------------------------------------------------
# Gmail SMTP (Required for email alerts)
# Use an App Password, not your Gmail password
# https://myaccount.google.com/apppasswords
# ------------------------------------------------------------
GMAIL_USER=your-email@gmail.com
GMAIL_APP_PASSWORD=your-app-password

# ------------------------------------------------------------
# Admin Contact
# ------------------------------------------------------------
ADMIN_EMAIL=your-email@gmail.com
ADMIN_PHONE=+1234567890

# Alert email recipient (where to send alert emails)
ALERT_EMAIL_TO=alerts@yourdomain.com

# ------------------------------------------------------------
# Cron Job Security (Required)
# Generate with: openssl rand -base64 32
# Used to authenticate cron job requests (uptime, pagespeed, etc.)
# Also set this in vercel.json cron headers
# ------------------------------------------------------------
CRON_SECRET=your-random-cron-secret

# ------------------------------------------------------------
# Vercel API (Optional - for deployment tracking)
# Get from: https://vercel.com/account/tokens
# ------------------------------------------------------------
VERCEL_API_TOKEN=your-vercel-token

# ------------------------------------------------------------
# OpenAI API (Required for AI-powered SEO analysis)
# Get from: https://platform.openai.com/api-keys
# ------------------------------------------------------------
OPENAI_API_KEY=sk-your-openai-api-key

# ------------------------------------------------------------
# Google Service Account (Required for GA4 & Search Console)
# Create at: Google Cloud Console → IAM → Service Accounts
# Export the JSON key and paste the entire JSON string below
# Grant access: GA4 property viewer, Search Console reader
# ------------------------------------------------------------
GOOGLE_APPLICATION_CREDENTIALS_JSON={"type":"service_account","project_id":"...","private_key":"...","client_email":"..."}

# ------------------------------------------------------------
# Google Analytics 4 Property IDs (Required for GA4 integration)
# Find at: GA4 Admin → Property Settings → Property ID
# Add one variable per website
# ------------------------------------------------------------
DRKEREMAL_GA4_PROPERTY_ID=123456789
ANITYA_GA4_PROPERTY_ID=123456789
GONGSAHNE_GA4_PROPERTY_ID=123456789
QIBOO_GA4_PROPERTY_ID=123456789

# ------------------------------------------------------------
# Google PageSpeed Insights API Key (Optional)
# Enable API at: Google Cloud Console → APIs & Services
# Free tier: 25,000 queries/day
# ------------------------------------------------------------
GOOGLE_PAGESPEED_API_KEY=your-pagespeed-api-key

# ------------------------------------------------------------
# Website Configuration
# Comma-separated list of monitored domains
# ------------------------------------------------------------
NEXT_PUBLIC_WEBSITES=drkeremal.com,gongsahne.com,anityacavehouse.com,qiboo.ai

# ------------------------------------------------------------
# App URL (Auto-set by Vercel, override for local development)
# ------------------------------------------------------------
NEXT_PUBLIC_SITE_URL=http://localhost:3000
